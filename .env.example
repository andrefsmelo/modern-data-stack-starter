# S3 bucket name (required)
BUCKET=acme-data-prod

# AWS credentials (alternative to ~/.aws/credentials or AWS_PROFILE)
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_PROFILE=default
# AWS_REGION=eu-west-1

# dbt / DuckDB
# S3_BUCKET=acme-data-prod
# S3_RAW_PREFIX=raw
# DBT_DUCKDB_PATH=dev.duckdb

# Data generation defaults
# SEED=42
# DAYS=30
# START_DATE=2026-01-01
# OUTPUT_DIR=./data
# FORMAT=raw_events

# Metabase
# MB_PORT=3000
# MB_USER=admin@modern-data-stack.local
# MB_PASS=Metabase123!